<?xml version="1.0" encoding="utf-8"?>
<!--
  String resources for the controller UI (MainActivity + pads). Verdict text comes
  from the shared decision model (:capability-core evaluate()); these are the
  display frames, action labels, and layout names around it.
-->
<resources>
    <string name="app_name">Phone Controller</string>

    <!-- Status line -->
    <string name="probing">Probing controller capability…</string>
