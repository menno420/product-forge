<?xml version="1.0" encoding="utf-8"?>
<!--
  Android app manifest. Declares the Bluetooth permissions the BluetoothHidDevice
  transport needs plus the Slice-3 capability-screen entry point (MainActivity). Built
  by CI's assembleDebug job (see app/build.gradle.kts + .github/workflows/android-ci.yml).
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Android 12+ (API 31+) runtime Bluetooth permissions. -->
    <uses-permission android:name="android.permission.BLUETOOTH_CONNECT" />
    <uses-permission android:name="android.permission.BLUETOOTH_ADVERTISE" />

    <!-- Legacy permissions for API 28..30 (maxSdkVersion so 31+ uses the new model). -->
    <uses-permission
        android:name="android.permission.BLUETOOTH"
        android:maxSdkVersion="30" />
    <uses-permission
        android:name="android.permission.BLUETOOTH_ADMIN"
        android:maxSdkVersion="30" />

    <!-- Voice commands (Slice 11): runtime-requested ONLY when the user enables the
         feature; listening runs foreground-only and prefers on-device recognition. -->
    <uses-permission android:name="android.permission.RECORD_AUDIO" />

    <!-- Local-play overlay (Slice 12): float controls over other apps + keep the
         overlay service alive while a game is in front. Both are opt-in: the user
         grants "draw over other apps" and enables the accessibility service by hand;
         nothing here runs unless they start overlay play. -->
    <uses-permission android:name="android.permission.SYSTEM_ALERT_WINDOW" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />

    <!-- Classic BT-HID needs Bluetooth hardware; not required=false so no-BT devices
         can still install and show the capability verdict. -->
    <uses-feature
        android:name="android.hardware.bluetooth"
        android:required="false" />

    <!-- DeviceDefault dark, no action bar: the controller IS the screen (Slice 8) —
         dark widgets + dark dialogs for free, no AndroidX theme dependency. -->
    <application
        android:label="@string/app_name"
        android:theme="@android:style/Theme.DeviceDefault.NoActionBar">
        <!-- The controller UI. exported=true so it is launchable as the app's MAIN
             activity. configChanges: rotation must NOT recreate the activity — a
             recreate tears down the HID registration and drops the live host
             connection mid-game; onConfigurationChanged rebuilds the layout by hand
             (portrait = stacked chrome, landscape = side panel + full-height pad). -->
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:configChanges="orientation|screenSize|screenLayout|keyboardHidden">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Local-play overlay (Slice 12). specialUse: an input-overlay tool is not
             one of Android's predefined FGS categories; sideload distribution has no
             Play FGS policy review. -->
        <service
            android:name=".overlay.OverlayPlayService"
            android:exported="false"
            android:foregroundServiceType="specialUse">
            <property
                android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
                android:value="on-screen game/app control overlay driven by the user" />
        </service>

        <!-- Injects synthetic taps/swipes into the foreground app. canRetrieveWindow
             Content=false (config) — it writes input, never reads the screen. -->
        <service
            android:name=".overlay.TapAccessibilityService"
            android:exported="false"
            android:permission="android.permission.BIND_ACCESSIBILITY_SERVICE">
            <intent-filter>
                <action android:name="android.accessibilityservice.AccessibilityService" />
            </intent-filter>
            <meta-data
                android:name="android.accessibilityservice"
                android:resource="@xml/tap_accessibility_config" />
        </service>
    </application>
</manifest>
